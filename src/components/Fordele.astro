---
//@ts-nocheck
import { Image } from "astro:assets";
import Forskel from "../assets/forskel.png";
import Fremtid from "../assets/fremtid.png";
import Faellesskab from "../assets/faellesskab.png";
import Profilbillede from "../assets/profilbillede.png";

import ForskelSlide1 from "../assets/forskel_slide1.png";
import ForskelSlide2 from "../assets/forskel_slide2.png";
import ForskelSlide3 from "../assets/forskel_slide3.png";
import ForskelSlide4 from "../assets/forskel_slide4.png";

import FremtidSlide1 from "../assets/fremtid_slide1.png";
import FremtidSlide2 from "../assets/fremtid_slide2.png";
import FaellesskabSlide1 from "../assets/faellesskab_slide1.png";
import FaellesskabSlide2 from "../assets/faellesskab_slide2.png";
---

<h1>Hvad får jeg ud af det?</h1>

<div class="highlights">
  <button popovertarget="forskelPopover">
    <Image class="highlight" src={Forskel} alt="forskel highlight" />
    <p>Forskel</p>
  </button>

  <button popovertarget="fremtidPopover">
    <Image class="highlight" src={Fremtid} alt="fremtid highlight" />
    <p>Fremtid</p>
  </button>

  <button popovertarget="faellesskabPopover">
    <Image class="highlight" src={Faellesskab} alt="Fællesskab highlight" />
    <p>Fællesskab</p>
  </button>
</div>

<!-- Popovers -->
  <div popover id="forskelPopover">
    <div></div>

    <div class="slideindhold">
      <p><Image class="profilbillede" src={Profilbillede} alt="Røde Kors Frivillige SoMe profilbillede"/><b>Forskel</b> lige nu</p>
      <div class="slideshow-container">
        <div class="mySlides fade">
          <Image
            src={ForskelSlide1}
            alt="Statistik hvor mange røde kors hjalp i 2025" class="forskelImg"
          />
        </div>

        <div class="mySlides fade">
          <Image
            src={ForskelSlide2}
            alt="Fordeling hvordan vi bruger pengene" class="forskelImg"
          />
        </div>

        <div class="mySlides fade">
          <Image src={ForskelSlide3} alt="Oversigt hvor kommer pengene fra" class="forskelImg" />
        </div>

        <div class="mySlides fade">
          <Image src={ForskelSlide4} alt="Oversigt over udgifter" class="forskelImg" />
        </div>

        

        <!-- Next and previous buttons -->
        <a class="prev" onclick="plusSlides(-1, this)">&#10094;</a>
        <a class="next" onclick="plusSlides(1, this)">&#10095;</a>
      </div>
      <br />

      <!-- The dots/circles -->
      <div style="text-align:center">
        <span class="dot" onclick="currentSlide(1, this)"></span>
        <span class="dot" onclick="currentSlide(2, this)"></span>
        <span class="dot" onclick="currentSlide(3, this)"></span>
      </div>

      <Image
        src={ForskelSlide1}
        alt="Statistik af hvor mange røde kors hjalp i 2025"
      />
    </div>
    <div>
      <button popovertarget="forskelPopover" class="close-button">&#128937</button>
    </div>
  </div>

  <div popover id="fremtidPopover">
    <div></div>

    <div class="slideindhold">
      <p><Image class="profilbillede" src={Profilbillede} alt="Røde Kors Frivillige SoMe profilbillede"/><b>Fremtid</b> lidt senere</p>

      <div class="slideshow-container">
        <div class="mySlides fade">
          <Image src={FremtidSlide1} alt="Billede af frivilligt" class="forskelImg"/>
        </div>

        <div class="mySlides fade">
         <Image src={FremtidSlide2} alt="Billede af frivilligt" class="forskelImg" />
        </div>

        <!-- Next and previous buttons -->
        <a class="prev" onclick="plusSlides(-1, this)">&#10094;</a>
        <a class="next" onclick="plusSlides(1)">&#10095;</a>
      </div>
      <br />

    </div>
    <div>
      <button popovertarget="fremtidPopover" class="close-button">&#128937</button>
    </div>
  </div>

  <div popover id="faellesskabPopover">
    <div></div>
    <div class="slideindhold">
      <p><Image class="profilbillede" src={Profilbillede} alt="Røde Kors Frivillige SoMe profilbillede"/><b>Fællesskab</b> altid</p>
      <div class="slideshow-container">
        <div class="mySlides fade">
          <Image class="forskelImg" src={FaellesskabSlide1} alt="Billede af fællesskab" />
        </div>

        <div class="mySlides fade">
          <Image class="forskelImg" src={FaellesskabSlide2} alt="Billede af fællesskab" />
        </div>

        <!-- Next and previous buttons -->
        <a class="prev" onclick="plusSlides(-1, this)">&#10094;</a>
        <a class="next" onclick="plusSlides(1, this)">&#10095;</a>
      </div>
      <br />

    </div>
    <div>
      <button popovertarget="faellesskabPopover" class="close-button">&#128937</button>
    </div>
  </div>


<style>
  /***STYLE SLIDESHOW***/

  * {
    box-sizing: border-box;
  }

  /* Slideshow container */
  .slideshow-container {
    max-width: 1000px;
    position: relative;
    margin: auto;
  }

  /* Hide the images by default */
  .mySlides {
    display: none;
  }

  /* Next & previous buttons */
  .prev,
  .next {
    cursor: pointer;
    position: absolute;
    top: 50%;
    width: auto;
    margin-top: -22px;
    padding: 16px;
    color: white;
    font-weight: bold;
    font-size: 18px;
    transition: 0.6s ease;
    border-radius: 0 3px 3px 0;
    user-select: none;
  }

  /* Position the "next button" to the right */
  .next {
    right: 0;
    border-radius: 3px 0 0 3px;
  }

  button {
    border: none;
    cursor: pointer;
    background-color: transparent;
  }

  .highlight {
    border-radius: 50%;
    margin-bottom: 1rem;
    border: solid 6px var(--primary-accentcolor);
    padding: 5px;
    transition: border 0.3s ease;
  }

    .highlight:hover{
    border: solid 6px var(--tertiary-accentcolor);
  }

  .slideindhold {
    background-color: #f4afa3;
    border-radius: 1rem;
    padding: 1rem;
height: 90vh;
width: 100%;
  }

.forskelImg{
  width: 60%;
  justify-self: center;
  align-items: center;
}

.profilbillede{
  width:auto;
  height: 30px;
}

p{
  display: flex;
  gap: 10px;
  align-items: center;
}
  .highlights {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin: auto;
    width: 60%;
    gap: 3rem;
    padding-bottom: 1rem;
  }

  [popover] {
    display: none;
    background-color: var(--primary-accentcolor);
    padding: 1.2rem;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 1.5rem;
    border: none;
    height: 100%;
    width: 100%;
  }

  [popover].open {
    display: grid;
  }

  [popover] p {
    color: var(--alternate-text-color);
    margin: 0;
    line-height: 1.6;
  }

  .close-button {
    color: var(--alternate-text-color);
    font-size: 3rem;
    font-weight: bold;
  }
</style>

<script is:inline>
  document.addEventListener("click", (event) => {
    const trigger = event.target.closest("[popovertarget]");
    if (trigger) {
      event.preventDefault();
      const id = trigger.getAttribute("popovertarget");
      const popover = document.getElementById(id);
      if (!popover) return;

      const isOpen = popover.classList.toggle("open");
      document.querySelectorAll("[popover].open").forEach((other) => {
        if (other !== popover) {
          other.classList.remove("open");
        }
      });

      if (!isOpen) {
        popover.classList.remove("open");
      }

      return;
    }

    if (!event.target.closest("[popover]")) {
      document.querySelectorAll("[popover].open").forEach((openPopover) => {
        openPopover.classList.remove("open");
      });
    }
  });
</script>

<script is:inline>
  let slideIndex = 1;
showSlides(slideIndex);

// Next/previous controls
function plusSlides(n) {
  showSlides((slideIndex += n));
}

// Thumbnail image controls
function currentSlide(n) {
  showSlides((slideIndex = n));
}

function showSlides(n) {
  let i;
  let slides = document.getElementsByClassName("mySlides");
  let dots = document.getElementsByClassName("dot");
  if (n > slides.length) {
    slideIndex = 1;
  }
  if (n < 1) {
    slideIndex = slides.length;
  }
  for (i = 0; i < slides.length; i++) {
    slides[i].style.display = "none";
  }
  for (i = 0; i < dots.length; i++) {
    dots[i].className = dots[i].className.replace(" active", "");
  }
  slides[slideIndex - 1].style.display = "block";
  dots[slideIndex - 1].className += " active";
}

</script>