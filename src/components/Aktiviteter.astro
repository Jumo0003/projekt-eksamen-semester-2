---
//@ts-nocheck
import AktivitetPopover from "./aktivitetPopover.astro";
import { Image } from "astro:assets";
import butiksfrivillig from "../assets/butiksfrivillig.png";
import parathjælper from "../assets/parathjalper_besogsven.png";
import kommunikation from "../assets/kommunikation.png";
import sortering from "../assets/sortering.png";
import ithjalp from "../assets/ithjalp.png";
import samarit from "../assets/samarit.png";
import indsamler from "../assets/indsamler.png";
import besogsven from "../assets/parathjalper_besogsven.png";

import lektiehjalper from "../assets/lektiehjalper.png";
import klubfrivillig from "../assets/klubfrivillig.png";
import ungpalinje from "../assets/ungpalinje.png";
import mentor from "../assets/mentor.png";
import hospitalscafe from "../assets/hospitalscafe.png";
import lejrleder from "../assets/lejrleder.png";
import asylcenter from "../assets/asylcenter.png";

import asylcenter2 from "../assets/supabase/asylcenter.webp";
---
<h1>Hvad kan jeg lave?</h1>
<ul id="accordion">
    <li>
        <input type="checkbox" id="first" checked>
        <label for="first"><h2>Røde Kors</h2><span>&#9654</span></label>
       <div class="content">
                           <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={butiksfrivillig} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Butiksfrivillig</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={parathjælper} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Parathjælper</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={kommunikation} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Kommunikation</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={sortering} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Sortering</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={ithjalp} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>It-hjælp</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={samarit} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Samarit</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={indsamler} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Indsamler</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={besogsven} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Besøgsven</h3>
                        </div>
                    </button>
       </div>
    </li>
      <li>
        <input type="checkbox" id="second">
        <label for="second"><h2>Ungdommens Røde Kors</h2><span>&#9654</span></label>
       <div class="content">
     <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={lektiehjalper} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Lektiehjælper</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={klubfrivillig} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Klubfrivillig</h3>
                        </div>
                    </button>

                     <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={ungpalinje} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Ung På Linje</h3>
                        </div>
                    </button>

                      <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={mentor} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Mentor</h3>
                        </div>
                    </button>

                     <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={butiksfrivillig} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Ungdomsbutik</h3>
                        </div>
                    </button>

                     <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={hospitalscafe} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Hospitalscafe</h3>
                        </div>
                    </button>

                     <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={lejrleder} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Lejrleder</h3>
                        </div>
                    </button>

                    <button popovertarget="aktivitetPopover" class="aktivitet">
                        <Image src={asylcenter} alt="aktivitet"/>
                        <div class="boxTitle">
                            <h3>Asylcenter</h3>
                        </div>
                    </button>
       </div>
    </li>
</ul>

<article id="aktivitetPopover">
<div>
<Image src={asylcenter2} alt="billede af aktiviteten"/>
</div>
<div>
<ul id="accordion">
    <li>
        <input type="checkbox" id="first" checked>
        <label for="first">Hvad skal jeg lave?<span>&#9654</span></label>
       <div class="content">
    Som frivillig på et asylcenter er der mange forskellige aktiviteter. Du har måske mest lyst til at lave gymnastik med børnene eller hjælpe i legestuen. Det kan også være, at du vil bruge din tid i syklubben eller på cykelværkstedet, hvor man er sammen om at lave noget praktisk. Eller måske har du en idé til et projekt, som du tror can være sjovt for asylansøgere? Du kan også blive repræsentant for et barn eller en ung, der er flygtet alene. Det vigtigste er, at du engagerer dig for en tid, så asylansøgerne oplever kontinuitet og en vedholdende relation. 
       </div>
    </li>
      <li>
        <input type="checkbox" id="second">
        <label for="second">Hvad får jeg ud af det?<span>&#9654</span></label>
       <div class="content">
Asylansøgere ønsker at mødes helt normalt med andre mennesker og få mere at vide om det land de er kommet til. Mange har mistet både familie og venner, men du kan være den positive relation, som minder dem om deres evner og håb for fremtiden. Dét er en god følelse.       </div>
    </li>
        <li>
        <input type="checkbox" id="third">
        <label for="third">Hvor lang tid skal jeg bruge?<span>&#9654</span></label>
       <div class="content">
Afhængigt af hvilken opgave du tager på asylcenteret, kan det være alt fra få timer om ugen, til flere timer dagligt.</div>
    </li>
        <li>
        <input type="checkbox" id="fourth">
        <label for="fourth">Hvordan kommer jeg i gang?<span>&#9654</span></label>
       <div class="content">
Asylansøgerne mangler måske en som dig? Tryk på den gule knap, hvis du er interesseret!</div>
    </li>
</ul>

<button popovertarget="aktivitetPopover">x</button>

</div>
</article>

<style>
button{
    background: none;
    border: none;
}

#accordion{ 
    margin: auto; /*du siger til hele harmonikaen at den skal være i midten*/
    width: 60%; /*du siger at den skal være 600px bred*/
}

#accordion li{
    list-style: none; /*du fjerner de små prikker ved siden af hver li*/
    width: 100%; /*du siger at hver li skal være 100% bred, altså 600px*/
    margin-bottom: 10px; /*du siger at der skal være 10px mellem hver li*/
  
}

#accordion li label{
    padding: 10px; /*du siger at der skal være 10px mellem indholdet og kanten af hver label*/
    display: flex; /*du siger at indholdet i hver label skal være i en fleksibel boks, så du kan justere det nemt*/
    align-items: center; /*du siger at indholdet i hver label skal være centreret lodret, så det ser pænt ud*/
    justify-content: space-between; /*du siger at indholdet i hver label skal være fordelt med plads imellem, så det ser pænt ud*/
    cursor: pointer; /*du siger at musen skal ændre sig til en hånd, når den er over hver label, så det indikerer at det er klikbart*/
    font-weight: 500; /*du siger at teksten i hver label skal være lidt tykkere, så det skiller sig ud*/
    color: var(--text-color); /*du siger at teksten i hver label skal have den farve, der er defineret i variablen --text-color, så det passer til temaet*/
    background: var(--primary-accentcolor); /*du siger at baggrunden skal være rød*/
}

#accordion li label span{
    transform: rotate(0deg); /*du siger at pilen i hver label skal være roteret 0 grader, så den peger til højre*/
    transition: transform 0.3s ease, color 0.3s ease; /*du siger at ændringen af rotationen og farven på pilen i hver label skal have en overgangseffekt, så det ser glat ud*/
    font-size: 22px; /*du siger at pilen i hver label skal være 22px stor, så den er tydelig og let at klikke på*/
    color: var(--secondary-accentcolor); /*du siger at farven på pilen i hver label skal være den farve, der er defineret i variablen --secondary-accentcolor, så det passer til temaet*/
}

#accordion li label span:hover{
    color: var(--tertiary-accentcolor); /*du siger at farven på pilen i hver label skal ændre sig til den farve, der er defineret i variablen --tertiary-accentcolor, når musen er over den, så det indikerer at det er klikbart*/
}

#accordion input[type="checkbox"]{
    display: none; /*du siger at checkboksene i hver label skal være skjulte, så de ikke vises på siden*/
}

#accordion input[type="checkbox"]:checked + label span{
    transform: rotate(90deg); /*du siger at pilen i hver label skal være roteret 90 grader, når den tilhørende checkbox er markeret, så den peger nedad*/
}

#accordion .content{
    padding: 0 10px; /*du siger at der skal være 10px mellem indholdet og kanten*/
    line-height: 26px; /*du siger at linjehøjden i hver content skal være 26px, så det er nemt at læse*/
    max-height: 0; /*du siger at den maksimale højde på hver content skal være 0, så det er skjult som standard*/
    overflow-y: auto; /*du siger at hvis indholdet i hver content er højere end den maksimale højde, skal der vises en lodret rullebjælke, så det er muligt at se alt indholdet*/
    transition: max-height 0.5s ease; /*du siger at ændringen af den maksimale højde på hver content skal have en overgangseffekt, så det ser glat ud*/
}

#accordion input[type="checkbox"]:checked + label + .content{
max-height: 400px; /*du siger at den maksimale højde på hver content skal være 400px, når den tilhørende checkbox er markeret, så det bliver synligt på siden*/
}

/********************/

.content {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 0.5rem;
  width: 100%;
  padding: 1rem;
  overflow-y: auto;
  background-color: var(--background-color);
}

.aktivitet {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 100%;
  background: var(--background-color);
  overflow: hidden;
  transition: transform 0.2s ease;
}

.aktivitet .boxTitle {
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.boxTitle {
  background-color: var(--secondary-accentcolor);
  padding: 1rem;
  text-align: left;
}

.aktivitet img {
  width: 100%;
  height: auto;
  object-fit: cover;

}

.aktivitet:hover .boxTitle {
  background-color: var(--tertiary-accentcolor);
}

@media (max-width: 400px) {
  .content {
    grid-template-columns: 1fr;
    gap: 8px;
  }

  #accordion li label {
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  #accordion li label span {
    font-size: 24px;
  }
}

/* width */
li .content::-webkit-scrollbar {
  width: 10px;
}

/* Track */
li .content::-webkit-scrollbar-track {
  background: #f1f1f100;
}

/* Handle */
li .content::-webkit-scrollbar-thumb {
  background: #b9b9b9;
  border-radius: 10px;
}
</style>