---
import heroVideo from "/hero_video.mp4";
import { Image } from "astro:assets";
import logo from "../assets/rkf_logo_header.png";
---
<div id="heroSection">
<Image class="logo"src={logo} alt="Røde Kors Frivillige Logo" />

<video controls playsinline preload="metadata" aria-label="En video med interviews af unge på Strøget">
  <source src={heroVideo} type="video/mp4" />
  Din browser understøtter ikke videoafspilleren.
</video>

<div class="dropdown">
  <button class="dropbtn">
    <span>&#9660</span>
  </button>
  <div class="dropdown-content">
    <a href="#fordeleSection">Fordele</a>
    <a href="#aktiviteterSection">Aktiviteter</a>
    <a href="#frivilligeSection">Frivillige</a>
    <a href="#faqSection">FAQ</a>
    <a href="#formSection">Bliv frivillig</a>
    <a href="#footer">Kontakt</a>
  </div>
</div>

</div>

<script>
  const video = document.getElementById('heroVideo') as HTMLVideoElement;
  if (video) {
    video.muted = false;
    video.volume = 1.0;
  }
</script>

