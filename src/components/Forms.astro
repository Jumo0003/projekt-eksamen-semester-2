<div class="popup_content" id="popupContent">
  <h3 id="popupTitel">Titel kommer her</h3>
  <p id="popupAktivitet">Aktivitet kommer her</p>
</div>

<script>
  const dataElement = document.getElementById("aktiviteter-data")
  const tekstData = dataElement.textContent
  const aktiviteter = JSON.parse(tekstData)


const buttons = document.querySelectorAll('.button'); 
buttons.forEach(function(button) {
  button.addEventListener('mouseover', function(event) {
     document.querySelector('.popup_content').style.top = event.clientY + 'px';
    document.querySelector('.popup_content').style.left = event.clientX + 'px';
    const type = this.getAttribute('data-type');
    const found = aktiviteter.find(function(a) {
      return a.titel === type;
    });
  document.getElementById('popupTitel').textContent = found.titel;
    document.getElementById('popupAktivitet').textContent = found.aktivitet;
    document.querySelector('.popup_content').style.display = 'block';
  });
   button.addEventListener('mouseout', function() {
  document.querySelector('.popup_content').style.display = 'none';
  });
});
  </script>

