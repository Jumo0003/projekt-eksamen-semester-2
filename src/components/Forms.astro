---
// HENT DATA FRA SUPABASE
const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/Aktiviteter?select=*`;
const apiKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY;

const options = {
  headers: {
    apikey: apiKey,
  },
};

let aktiviteterData = [];

try {
  const response = await fetch(url, options);
  if (!response.ok) {
    console.error("Fetch fejl:", response.status, response.statusText);
  }
  aktiviteterData = await response.json();
  console.log("Data fra Supabase:", aktiviteterData);
} catch (error) {
  console.error("Fejl ved hentning af data:", error);
}

