/***hover popup */

<div class="popup_content" id="popupContent">
  <h3 id="popupTitel">Titel kommer her</h3>
  <p id="popupAktivitet">Aktivitet kommer her</p>
</div>

<style>

.popup_content{
  display: none;
  position: absolute; 
  background-color: var(--primary-accentcolor);
  color: var(--alternate-text-color);
  padding: 10px;
  border-radius: 5px;
}

#formSection{
  margin: auto;
  margin-top: 3rem;
}

.button {
  background-color: var(--secondary-accentcolor);
  border: none;
  border-radius: 100%;
  color: var(--alternate-text-color);
  padding: 5px 10px;
  text-align: center;
  text-decoration: none;
  display: inline-block;
  font-size: 16px;
  cursor: pointer;
}

form{
    display: grid;
    background-color: var(--primary-accentcolor);
  gap: 10px;
padding: 15px;
width: 55%;
 align-items: center;
  justify-content: center;
  margin: auto;
  margin-bottom: 25px;
  color: var(--alternate-text-color);
}

.Frivillighedstyper{
  display: grid; 
  grid-template-columns: 1fr 1fr ;
   grid-template-rows:repeat(7,  1fr);
gap:10px;
  padding:15px;
}

.FrivilligValg{
  display: flex;
  margin: 10px;
}

a{
  margin-left: auto
  ;
}

p, h3, label{
  color:var(--alternate-text-color);
}

p{
    max-width: 65ch;
}

input[type="text"],input[type="email"],input[type="number"], textarea{
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 4px;
  box-sizing: border-box;
   background-color: var(--secondary-accentcolor);
  appearance: none;
  cursor: pointer;
}

input[type="checkbox"]{
  background-color: var(--secondary-accentcolor);
  appearance: none;
    width: 25px;
  height: 25px;
  border: 2px;
  display:flex;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
}

input[type="checkbox"]:checked::before{
  content: "✕";
  font-size: 20px;
}


.sammentykke{
  display:flex; 
  gap: 25px;
}

input[type="submit"]{
   background-color: var(--tertiary-accentcolor);
  appearance: none;
  cursor: pointer;
  border: none; 
     width: 200px;
padding: 1rem;
  border-radius: 10px;
  font-size: 16px;
}

input[type="submit"]:hover{
   background-color: var(--tertiary-accentcolor);
}


@media screen and (max-width: 600px){
form, #formSection
{width:90%;}
.Frivillighedstyper{
  grid-template-columns: 1fr;
}
}
</style>

