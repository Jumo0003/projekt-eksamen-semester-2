---
const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/Aktiviteter?select=*`;
const apiKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY;

const options = {
  headers: {
    apikey: apiKey,
  },
};

const aktiviteterData = await fetch(url, options)
  .then((res) => res.json());

console.log(aktiviteterData);
